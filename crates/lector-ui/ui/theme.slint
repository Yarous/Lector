export struct ThemeColors {
    bg: color,
    surface: color,
    surface-hover: color,
    surface-active: color,
    border: color,
    border-strong: color,
    text-primary: color,
    text-secondary: color,
    text-muted: color,
    accent: color,
    accent-hover: color,
    accent-text: color,
    success: color,
    success-bg: color,
    danger: color,
    danger-bg: color,
    warning: color,
    warning-bg: color,
    shadow: color,
    selection: color,
    scrollbar: color,
}

export global Theme {
    in-out property <bool> dark-mode: false;

    out property <ThemeColors> colors: dark-mode ? {
        bg: #0d1117,
        surface: #161b22,
        surface-hover: #1c2333,
        surface-active: #242d3d,
        border: #30363d,
        border-strong: #484f58,
        text-primary: #e6edf3,
        text-secondary: #b1bac4,
        text-muted: #6e7681,
        accent: #58a6ff,
        accent-hover: #79b8ff,
        accent-text: #0d1117,
        success: #3fb950,
        success-bg: #0d2818,
        danger: #f85149,
        danger-bg: #3d1214,
        warning: #d29922,
        warning-bg: #2e2215,
        shadow: #01040940,
        selection: #1f3d5e,
        scrollbar: #30363d,
    } : {
        bg: #f6f8fa,
        surface: #ffffff,
        surface-hover: #f3f4f6,
        surface-active: #e9ecef,
        border: #d0d7de,
        border-strong: #afb8c1,
        text-primary: #1f2328,
        text-secondary: #656d76,
        text-muted: #8b949e,
        accent: #0969da,
        accent-hover: #0550ae,
        accent-text: #ffffff,
        success: #1a7f37,
        success-bg: #dafbe1,
        danger: #cf222e,
        danger-bg: #ffebe9,
        warning: #9a6700,
        warning-bg: #fff8c5,
        shadow: #0104091a,
        selection: #ddf4ff,
        scrollbar: #d0d7de,
    };

    out property <length> radius-sm: 6px;
    out property <length> radius-md: 10px;
    out property <length> radius-lg: 14px;
    out property <length> radius-xl: 20px;

    out property <length> spacing-xs: 4px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-md: 12px;
    out property <length> spacing-lg: 16px;
    out property <length> spacing-xl: 24px;

    out property <length> font-xs: 11px;
    out property <length> font-sm: 12px;
    out property <length> font-md: 13px;
    out property <length> font-lg: 15px;
    out property <length> font-xl: 18px;
    out property <length> font-xxl: 24px;
    out property <length> font-hero: 32px;
}